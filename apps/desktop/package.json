{
  "name": "@orquester/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5174\" \"wait-on http://127.0.0.1:5174 && cross-env ORQUESTER_DESKTOP_DEV_URL=http://127.0.0.1:5174 electron .\"",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@orquester/ui": "workspace:*",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
