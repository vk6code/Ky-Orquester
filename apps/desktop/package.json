{
  "name": "@orquester/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 6174\" \"pnpm build:main --watch\" \"wait-on http://127.0.0.1:6174 dist-electron/main.cjs && cross-env ORQUESTER_DESKTOP_DEV_URL=http://127.0.0.1:6174 electron .\"",
    "build:main": "tsx scripts/build-main.ts",
    "build:ui": "vite build",
    "build:electron": "electron-builder",
    "build": "pnpm build:main && pnpm build:ui && pnpm build:electron",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@orquester/daemon": "workspace:*",
    "@orquester/ui": "workspace:*",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3",
    "vite-plugin-svgr": "^5.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.orquester.desktop",
    "productName": "Orquester",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "executableName": "orquester"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "executableName": "orquester"
    },
    "linux": {
      "target": ["AppImage"],
      "executableName": "orquester",
      "category": "Utility"
    }
  }
}
