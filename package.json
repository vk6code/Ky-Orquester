{
  "name": "orquester",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "cross-env ORQUESTER_APPDIR=./.stage pnpm --filter @orquester/desktop dev",
    "dev:bare": "pnpm --filter @orquester/desktop dev",
    "dev:daemon": "cross-env ORQUESTER_APPDIR=./.stage tsx watch apps/daemon/src/index.ts",
    "dev:daemon:bare": "tsx watch apps/daemon/src/index.ts",
    "dev:web": "cross-env VITE_ORQUESTER_API_URL=http://127.0.0.1:47831 pnpm --filter @orquester/web dev",
    "dev:desktop": "pnpm --filter @orquester/desktop dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm -r typecheck"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}