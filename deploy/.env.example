# Variables de entorno para docker-compose.yml
# Copiar a .env y editar con tus valores

# ===== Orquester =====
# Puerto del daemon (expuesto al host)
ORQUESTER_PORT=57831

# Activar HTTP remoto (true/false)
ORQUESTER_HTTP_ENABLED=true

# Host donde escucha el daemon (0.0.0.0 = todas las interfaces)
ORQUESTER_HTTP_HOST=0.0.0.0

# Password para autenticación (mínimo 8 caracteres)
ORQUESTER_HTTP_PASSWORD=tu_password_seguro_aqui

# ===== API Keys de Agentes =====
# Claude Code
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# OpenAI Codex
OPENAI_API_KEY=sk-proj-tu-api-key-aqui

# Kimi Code
KIMI_API_KEY=tu-kimi-api-key-aqui

# DeepSeek CLI
DEEPSEEK_API_KEY=sk-ds-tu-api-key-aqui

# ===== Directorio de proyectos (opcional, montado en /projects) =====
PROJECTS_DIR=./projects

# ===== Preset Gorila360 (opcional) =====
# El runner genérico de loops (/api/loops) funciona sin esto.
# Define la raíz del monorepo Gorila360 SOLO si quieres habilitar los
# endpoints /api/gorila360/* (worktrees, loops, pipelines, plans).
# ORQUESTER_GORILA360_ROOT=/ruta/al/gorila360
# Opcionales (derivan de ORQUESTER_GORILA360_ROOT si se omiten):
# ORQUESTER_GORILA360_SCRIPTS=/ruta/al/gorila360/scripts
# ORQUESTER_GORILA360_PLANS_DIR=/ruta/al/gorila360/frontend/docs/superpowers/plans
# Directorio de los scripts de Orquester (por defecto: ./scripts del repo)
# ORQUESTER_SCRIPTS_DIR=/ruta/al/repo/scripts
